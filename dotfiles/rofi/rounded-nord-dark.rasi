/* ROUNDED THEME FOR ROFI */
/* Author: Newman Sanchez (https://github.com/newmanls) */

* {
    bg0:    #1e1e2e;
    bg1:    #6c7086;
    bg2:    #4C566A80;
    bg3:    #11111b;
    fg0:    #cdd6f4;
    fg1:    #ECEFF4;
    fg2:    #D8DEE9;
    fg3:    #4C566A;
}

@import "rounded-template.rasi"

element selected {
    text-color: @bg1;
}
